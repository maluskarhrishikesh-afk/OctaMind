{
  "_comment": "Example settings file. Copy to config/settings.json and fill values. DO NOT commit real secrets.",

  "llm_api_keys": {
    "GITHUB_TOKEN": "your_github_token_here",
    "OPENAI_API_KEY": "your_openai_api_key_here",
    "ANTHROPIC_API_KEY": "your_anthropic_api_key_here"
  },

  "google": {
    "oauth_credentials_path": "config/credentials.json",
    "gmail_token_path": "config/token.json",
    "drive_token_path": "config/drive_token.json"
  },

  "whatsapp": {
    "_comment": "Meta WhatsApp Cloud API credentials — see documentation/WHATSAPP_SETUP.md",
    "access_token": "EAAxxxxxxxxxx_your_permanent_access_token",
    "phone_number_id": "123456789012345",
    "verify_token": "any_secret_string_you_choose",
    "webhook_port": 9001
  },

  "linkedin": {
    "_comment": "LinkedIn API credentials — see documentation/setup/LINKEDIN_SETUP.md",
    "client_id": "your_linkedin_app_client_id",
    "client_secret": "your_linkedin_app_client_secret",
    "access_token": "your_long_lived_access_token_after_oauth",
    "org_urn": "urn:li:organization:your_organization_id",
    "redirect_uri": "http://localhost:8080/callback",
    "post_as_org": true,
    "image_gen_backend": "openai"
  }
}
