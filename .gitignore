# ── Runtime data (user-specific, potentially sensitive) ───────────────────────
# This directory holds all live application data including:
#   - assistants.json      → Telegram bot tokens, channel configs
#   - *_messages.json      → private message histories
#   - habits/links/etc.    → personal user data
data/

# Agent registry & runtime state (machine-specific, may contain tokens)
agents.json
running_agents.json
running_tg_pollers.json

# ── Personal Assistant memory (private user context) ──────────────────────────
memory/

# Model Cache
model_cache/

# Logs
*.log
logs/

# ── Misc ──────────────────────────────────────────────────────────────────────
replacements.txt

# Ignore local error notes generated during development
errors/errors.txt
errors/new_implementation.txt
